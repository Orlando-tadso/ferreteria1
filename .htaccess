<IfModule mod_rewrite.c>
    RewriteEngine On

    # Compatibilidad con rutas antiguas/publicadas con prefijo /ferreteria1
    RewriteRule ^ferreteria1/login\.html$ frontend/login.html [L,R=302]
    RewriteRule ^ferreteria1/(.*)$ $1 [L,R=302]
    
    # Permitir archivos y directorios reales
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # Redirigir requests a /api/* al backend
    RewriteRule ^api/(.*)$ backend/api/$1 [L,QSA]
    
    # Redirigir requests a /frontend/* 
    RewriteRule ^frontend/(.*)$ frontend/$1 [L,QSA]
    
    # Mantener login.php accesible
    RewriteRule ^login\.php$ - [L]
    
    # Permitir public/
    RewriteRule ^public/(.*)$ public/$1 [L,QSA]
</IfModule>

# Habilitar compresión
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
</IfModule>

# Caché de navegador
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType text/javascript "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
</IfModule>

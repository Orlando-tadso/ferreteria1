# .htaccess - Backend
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Permitir archivos y directorios reales
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # Redirigir todas las solicitudes al archivo correcto basado en la ruta
    # /api/productos.php?...
    RewriteRule ^api/productos(.*)$ api/productos.php%{QUERY_STRING} [L,QSA]
    RewriteRule ^api/ventas(.*)$ api/ventas.php%{QUERY_STRING} [L,QSA]
    RewriteRule ^api/auth(.*)$ api/auth.php%{QUERY_STRING} [L,QSA]
</IfModule>

# CORS Headers
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type, Authorization"
</IfModule>

# Prevenir acceso directo a config.php
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

<Files "middleware.php">
    Order allow,deny
    Deny from all
</Files>
